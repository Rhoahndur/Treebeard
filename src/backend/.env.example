# TreeBeard Backend - Environment Variables
# Copy this file to .env and update with your values

# =============================================================================
# Application
# =============================================================================
APP_NAME=TreeBeard Energy Recommendation API
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgresql://treebeard:treebeard@localhost:5432/treebeard
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_ECHO=False

# =============================================================================
# Redis Cache
# =============================================================================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=86400

# =============================================================================
# API Configuration
# =============================================================================
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
MAX_UPLOAD_SIZE_MB=10
ADMIN_API_ENABLED=false

# =============================================================================
# Security
# =============================================================================
SECRET_KEY=development-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440
RATE_LIMIT_PER_USER=100/minute
RATE_LIMIT_PER_IP=1000/hour
RECOMMENDATION_RATE_LIMIT_PER_MINUTE=10

# =============================================================================
# Recommendation Engine
# =============================================================================
RECOMMENDATION_CACHE_TTL_SECONDS=86400
MAX_RECOMMENDATIONS=3

# =============================================================================
# External APIs — OpenRouter (recommended for demo, free tier available)
# Sign up at https://openrouter.ai/ and get a free API key
# =============================================================================
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# `openrouter/free` is OpenRouter's routing pseudo-model — it auto-selects any
# available free-tier backend per request. Simplest option for a demo that wants
# "whichever free model is available" without maintaining a list by hand.
OPENROUTER_MODEL=openrouter/free
# Optional explicit fallback list. Leave unset to let `OPENROUTER_MODEL` handle
# routing on its own. When set, the service sends this list (primary first) as
# `extra_body.models` so OpenRouter tries each in order. Use this if you want to
# pin specific free models instead of trusting the auto-router. Env var accepts
# either a JSON array or a comma-separated string.
# Verified free model IDs (as of 2026-04-11; OpenRouter's free catalog rotates —
# double-check at https://openrouter.ai/models?q=free before relying on any):
#   google/gemma-4-31b-it:free
#   nvidia/nemotron-3-super-120b-a12b:free
#   minimax/minimax-m2.5:free
#   arcee-ai/trinity-large-preview:free
# OPENROUTER_FALLBACK_MODELS=["google/gemma-4-31b-it:free", "nvidia/nemotron-3-super-120b-a12b:free", "minimax/minimax-m2.5:free"]

# =============================================================================
# External APIs — OpenAI (optional fallback, requires paid key)
# Only used if OPENROUTER_API_KEY is not set
# =============================================================================
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# Data Processing
# =============================================================================
MIN_USAGE_MONTHS=3
PREFERRED_USAGE_MONTHS=12

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
